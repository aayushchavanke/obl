# The Obsidian Lens — Environment Variables Template
# Copy this file to .env and fill in your values.
# The actual .env file is gitignored and will never be committed.

# AlienVault OTX Threat Intelligence API Key (required for OTX capture mode)
# Get a free key at: https://otx.alienvault.com/api
OTX_API_KEY=your_otx_api_key_here

# Optional: Override defaults
# OTX_BASE_URL=https://otx.alienvault.com
# OTX_TIMEOUT=8
